# AT Protocol credentials
ATHERE_HANDLE=yourhandle.bsky.social
ATHERE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Current location (lat/lng decimal degrees)
# v0: set these at startup; Nominatim integration planned
ATHERE_LAT=0.0
ATHERE_LNG=0.0

# H3 resolution for publishing (0-15, default 7 = neighborhood ~5 km²)
ATHERE_H3_RES=7
