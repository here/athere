{
  "lexicon": 1,
  "id": "community.athere.geo.post",
  "defs": {
    "main": {
      "type": "record",
      "description": "A text post anchored to an H3 hexagonal cell.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["text", "h3Cell", "h3Res", "createdAt"],
        "properties": {
          "text": {
            "type": "string",
            "maxGraphemes": 300,
            "maxLength": 3000,
            "description": "The text content of the post."
          },
          "h3Cell": {
            "type": "string",
            "description": "H3 cell ID as a hex string (e.g. '87283082effffff')."
          },
          "h3Res": {
            "type": "integer",
            "minimum": 0,
            "maximum": 15,
            "description": "H3 resolution at which h3Cell was computed."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "ISO 8601 creation timestamp."
          },
          "langs": {
            "type": "array",
            "items": { "type": "string", "format": "language" },
            "maxLength": 3,
            "description": "BCP-47 language tags (e.g. ['en'])."
          }
        }
      }
    }
  }
}
