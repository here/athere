{
  "lexicon": 1,
  "id": "community.athere.geo.post",
  "defs": {
    "main": {
      "type": "record",
      "description": "A text post anchored to an H3 hexagonal cell.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["text", "location", "createdAt"],
        "properties": {
          "text": {
            "type": "string",
            "maxGraphemes": 300,
            "maxLength": 3000,
            "description": "The text content of the post."
          },
          "location": {
            "type": "union",
            "refs": [
              "community.lexicon.location.hthree",
              "community.lexicon.location.geo"
            ],
            "description": "The geographic location of the post. Preferred type is community.lexicon.location.hthree."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "ISO 8601 creation timestamp."
          },
          "langs": {
            "type": "array",
            "items": { "type": "string", "format": "language" },
            "maxLength": 3,
            "description": "BCP-47 language tags (e.g. ['en'])."
          }
        }
      }
    }
  }
}
